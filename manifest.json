{
  "_version": "1.40.0",
  "sap.app": {
    "id": "otccockpit",
    "type": "application",
    "title": "OTC Order Cockpit",
    "description": "Fiori-style cockpit to track sales orders across the Order-to-Cash chain.",
    "applicationVersion": { "version": "1.0.0" }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "otccockpit.view.App",
      "type": "XML",
      "id": "app",
      "async": true
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": { "sap.m": {}, "sap.ui.core": {} }
    },
    "models": {
      "": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/orders.json"
      }
    }
  }
}
